# Database
DATABASE_URL=postgresql+psycopg://agent:agent@localhost:5432/agent_crossing

# LLM provider selection: ollama | google_ai_studio
LLM_PROVIDER=ollama
LLM_TIMEOUT_SECONDS=30

# Generation + embedding model names
LLM_MODEL=qwen2.5:7b-instruct
EMBEDDING_MODEL=bge-m3

# Ollama endpoint (used when LLM_PROVIDER=ollama)
LLM_BASE_URL=http://localhost:11434

# Google AI Studio API key (used when LLM_PROVIDER=google_ai_studio)
GOOGLE_AI_STUDIO_API_KEY=

# Google AI Studio example
# LLM_PROVIDER=google_ai_studio
# LLM_MODEL=gemini-2.5-flash-lite
# EMBEDDING_MODEL=gemini-embedding-001
