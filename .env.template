# Database
DATABASE_URL=postgresql+psycopg://agent:agent@localhost:5432/agent_crossing

# LLM provider selection: litellm | ollama | google_ai_studio
LLM_PROVIDER=litellm
LLM_TIMEOUT_SECONDS=30

# Runtime tick scheduler interval in real seconds
WORLD_TICK_INTERVAL_SECONDS=1.0

# Generation + embedding model names
LLM_MODEL=ollama_chat/qwen2.5:7b-instruct
EMBEDDING_MODEL=ollama/bge-m3

# LiteLLM / OpenAI-compatible gateway endpoint
LLM_BASE_URL=https://model.fredly.dev
LLM_API_KEY=

# Direct Google AI Studio key (used when LLM_PROVIDER=google_ai_studio)
GOOGLE_AI_STUDIO_API_KEY=

